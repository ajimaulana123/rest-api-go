PORT=8080
JWT_SECRET=change-this-secret-in-production

SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_DB_PASSWORD=your-database-password

# Region: lihat di Supabase Dashboard → Project Settings → General
SUPABASE_REGION=ap-southeast-1

# aws-1 untuk project baru; jika gagal coba aws-0
SUPABASE_POOLER=aws-1

# session = pooler IPv4 (disarankan Windows) | direct = db.*.supabase.co | transaction = port 6543
SUPABASE_DB_MODE=session

# Opsional: override connection string dari Dashboard → Database
# DATABASE_URL=postgresql://postgres.ref:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
